      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/src/DemoPerCorsoClaude/bin/Debug/net10.0/DemoPerCorsoClaude.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/DemoPerCorsoClaude",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
